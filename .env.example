# ═══════════════════════════════════════════════════════════
#  CORE OS — Environment Variables  (v11)
#  cp .env.example .env  then fill in values
# ═══════════════════════════════════════════════════════════

# ── REQUIRED IN ALL ENVIRONMENTS ──────────────────────────

# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
# Must be STABLE across restarts — changing it logs out everyone.
SECRET_KEY=change-me-generate-a-real-32-char-hex-key

# 'development' | 'production' | 'testing'
FLASK_ENV=development

# ── REQUIRED IN PRODUCTION ────────────────────────────────

# PostgreSQL (SQLite rejected at startup in production)
# DATABASE_URL=postgresql://user:password@host:5432/coreos

# Redis for rate limiting across Gunicorn workers
# RATELIMIT_STORAGE_URI=redis://localhost:6379/0

# ── EMAIL / PASSWORD RESET ────────────────────────────────
# Without SMTP in production, startup will fail.
# For Gmail: use App Passwords (myaccount.google.com/apppasswords)
# MAIL_SERVER=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USE_TLS=true
# MAIL_USERNAME=your-email@gmail.com
# MAIL_PASSWORD=your-app-password
# MAIL_FROM=noreply@coreos.app

# ── OPTIONAL ──────────────────────────────────────────────
# LOG_FILE=/var/log/coreos/app.log
# PORT=5000
